{
  "name": "vedaai-backend",
  "version": "1.0.0",
  "description": "VedaAI Assessment Creator — Backend API Server",
  "main": "dist/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run worker\"",
    "dev:api": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:all": "node start-all.js",
    "worker": "ts-node-dev --respawn --transpile-only src/queues/worker.ts",
    "typecheck": "tsc --noEmit --pretty false"
  },
  "dependencies": {
    "bullmq": "^5.4.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.4",
    "express": "^4.18.2",
    "groq-sdk": "^1.2.1",
    "ioredis": "^5.3.2",
    "mammoth": "^1.12.0",
    "mongoose": "^8.2.0",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^2.4.5",
    "socket.io": "^4.7.4",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.20",
    "concurrently": "^9.2.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.2"
  }
}
